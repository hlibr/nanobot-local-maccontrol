    <string>/Users/gleb/.nanobot/logs/gateway.err.log</string>
    <key>StandardOutPath</key>
    <string>/Users/gleb/.nanobot/logs/gateway.out.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Library/Frameworks/Python.framework/Versions/3.13/bin</string>
    </dict>
</dict>
</plist>
